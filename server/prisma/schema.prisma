// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  EDITOR
  VIEWER
}

enum ElementType {
  FREEHAND
  RECT
  CIRCLE
  ARROW
  LINE
  STICKY
  TEXT
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  username       String         @unique
  passwordHash   String?        @map("password_hash")
  avatarUrl      String?        @map("avatar_url")
  oauthProvider  String?        @map("oauth_provider")
  oauthId        String?        @map("oauth_id")
  boards         Board[]        @relation("BoardOwner")
  memberships    BoardMember[]
  createdElements Element[]     @relation("ElementCreator")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@map("users")
}

model Board {
  id          String        @id @default(uuid())
  title       String
  ownerId     String        @map("owner_id")
  owner       User          @relation("BoardOwner", fields: [ownerId], references: [id])
  shareCode   String        @unique @map("share_code")
  isPublic    Boolean       @default(false) @map("is_public")
  settings    Json?
  members     BoardMember[]
  elements    Element[]
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@map("boards")
}

model BoardMember {
  id       String   @id @default(uuid())
  boardId  String   @map("board_id")
  board    Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  userId   String   @map("user_id")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     Role     @default(EDITOR)
  joinedAt DateTime @default(now()) @map("joined_at")

  @@unique([boardId, userId])
  @@map("board_members")
}

model Element {
  id        String      @id @default(uuid())
  boardId   String      @map("board_id")
  board     Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdBy String      @map("created_by")
  creator   User        @relation("ElementCreator", fields: [createdBy], references: [id])
  type      ElementType
  data      Json
  zIndex    Int         @default(0) @map("z_index")
  isDeleted Boolean     @default(false) @map("is_deleted")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@map("elements")
}
